{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loyaltyos.local/schemas/programme-config.schema.json",
  "title": "LoyaltyOS Programme Config (canonical)",
  "type": "object",
  "additionalProperties": false,
  "required": ["programmeIdentity", "pointsEconomics", "conflictPolicy", "tiers", "expiry", "eventSchema"],
  "properties": {
    "programmeIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["programmeName", "pointsName", "pointsSymbol", "baseCurrency"],
      "properties": {
        "programmeName": { "type": "string", "minLength": 2, "maxLength": 255 },
        "pointsName": { "type": "string", "minLength": 1, "maxLength": 64 },
        "pointsSymbol": { "type": "string", "minLength": 1, "maxLength": 6 },
        "baseCurrency": { "type": "string", "minLength": 3, "maxLength": 3 }
      }
    },
    "pointsEconomics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pointsMonetaryValue", "basePointsRate"],
      "properties": {
        "pointsMonetaryValue": { "type": "number", "exclusiveMinimum": 0 },
        "basePointsRate": { "type": "number", "exclusiveMinimum": 0 },
        "caps": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "daily": { "type": ["number", "null"], "exclusiveMinimum": 0 },
            "monthly": { "type": ["number", "null"], "exclusiveMinimum": 0 }
          }
        },
        "welcomeBonus": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "amount": { "type": "number", "minimum": 0 },
            "tierOverrides": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["tierUid", "amount"],
                "properties": {
                  "tierUid": { "type": "string", "minLength": 1, "maxLength": 64 },
                  "amount": { "type": "number", "minimum": 0 }
                }
              }
            }
          }
        }
      }
    },
    "conflictPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultStrategy", "allowRuleOverride"],
      "properties": {
        "defaultStrategy": { "type": "string", "enum": ["BEST_FOR_CUSTOMER", "BEST_FOR_BUSINESS"] },
        "allowRuleOverride": { "type": "boolean" }
      }
    },
    "tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "tiers"],
      "properties": {
        "enabled": { "type": "boolean" },
        "thresholdType": { "type": "string", "enum": ["LIFETIME_POINTS", "ROLLING_SPEND_12M", "TXN_COUNT"] },
        "reviewCycle": { "type": "string", "enum": ["ANNUAL", "QUARTERLY"] },
        "gracePeriodDays": { "type": "integer", "minimum": 0, "maximum": 365 },
        "downgradeWarningDays": { "type": "integer", "minimum": 0, "maximum": 365 },
        "tiers": {
          "type": "array",
          "minItems": 1,
          "maxItems": 10,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tierUid", "name", "rank", "entryThreshold", "maintenanceThreshold", "multiplier"],
            "properties": {
              "tierUid": { "type": "string", "minLength": 1, "maxLength": 64 },
              "name": { "type": "string", "minLength": 1, "maxLength": 64 },
              "rank": { "type": "integer", "minimum": 1, "maximum": 10 },
              "entryThreshold": { "type": "number", "minimum": 0 },
              "maintenanceThreshold": { "type": "number", "minimum": 0 },
              "multiplier": { "type": "number", "minimum": 1 },
              "expiryExtensionMonths": { "type": ["integer", "null"], "minimum": 0, "maximum": 120 }
            }
          }
        }
      }
    },
    "expiry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model", "processMode"],
      "properties": {
        "model": { "type": "string", "enum": ["ROLLING", "FIXED_DATE"] },
        "rollingMonths": { "type": ["integer", "null"], "minimum": 1, "maximum": 240 },
        "fixedDate": { "type": ["string", "null"], "format": "date" },
        "tierExtensionsEnabled": { "type": "boolean" },
        "notificationScheduleDays": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0, "maximum": 365 },
          "minItems": 1,
          "maxItems": 10
        },
        "processMode": { "type": "string", "enum": ["OVERNIGHT_BATCH"] },
        "breakage": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "reportFrequency", "accountingCutoffTimezone", "exportEnabled"],
          "properties": {
            "enabled": { "type": "boolean" },
            "reportFrequency": { "type": "string", "enum": ["DAILY", "MONTHLY"] },
            "accountingCutoffTimezone": { "type": "string", "minLength": 1, "maxLength": 64 },
            "exportEnabled": { "type": "boolean" },
            "exportFormats": {
              "type": "array",
              "items": { "type": "string", "enum": ["CSV", "XLSX", "PDF"] },
              "minItems": 1,
              "maxItems": 3
            },
            "includeTierBreakdown": { "type": "boolean" },
            "includeProgrammeBreakdown": { "type": "boolean" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "model": { "const": "ROLLING" } } },
          "then": { "required": ["rollingMonths"] }
        },
        {
          "if": { "properties": { "model": { "const": "FIXED_DATE" } } },
          "then": { "required": ["fixedDate"] }
        }
      ]
    },
    "eventSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "standardFields", "customFields", "backwardCompatibilityDays"],
      "properties": {
        "version": { "type": "integer", "minimum": 1 },
        "standardFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "required"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 64 },
              "type": { "type": "string", "enum": ["string", "number", "integer", "boolean", "date-time", "object"] },
              "required": { "type": "boolean" }
            }
          }
        },
        "customFields": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "required"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-zA-Z][a-zA-Z0-9_]*$", "maxLength": 64 },
              "type": { "type": "string", "enum": ["string", "number", "integer", "boolean", "date-time", "object"] },
              "required": { "type": "boolean" },
              "validation": { "type": ["object", "null"] }
            }
          }
        },
        "backwardCompatibilityDays": { "type": "integer", "minimum": 0, "maximum": 365 }
      }
    },
    "webhooks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sandboxEndpointUrl": { "type": "string" },
        "productionEndpointUrl": { "type": "string" },
        "subscribedEvents": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}

